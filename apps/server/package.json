{
	"name": "@papyrus/server",
	"version": "0.1.0",
	"description": "Papyrus headless server — agents, terminals, and files over tRPC (HTTP + WebSocket)",
	"type": "module",
	"private": true,
	"scripts": {
		"build:daemon": "bun run scripts/build-daemon.ts",
		"dev": "bun run build:daemon && bun run src/cli.ts serve",
		"start": "node --experimental-strip-types src/cli.ts serve",
		"typecheck": "tsc --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"@papyrus/server-core": "workspace:*",
		"@trpc/server": "^11.7.1",
		"node-pty": "1.1.0",
		"superjson": "^2.2.5",
		"ws": "^8.18.0",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@trpc/client": "^11.7.1",
		"esbuild": "^0.25.12",
		"@types/node": "^24.0.0",
		"@types/ws": "^8.18.1",
		"typescript": "^5.9.3"
	}
}
