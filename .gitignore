# Graphify: track the graph itself (graph.json, manifest.json, GRAPH_REPORT.md,
# graph.html) so it persists across machines; ignore regenerable cache + run costs
**/graphify-out/cache/
**/graphify-out/cost.json
**/graphify-out/.graphify_detect.err
**/graphify-out/.graphify_python
**/graphify-out/.graphify_root
**/graphify-out/.commits_since_update
**/graphify-out/.needs_update
**/graphify-out/.hook_update.log
**/graphify-out/20*/

# Codex workspace config (track only shared config/symlinks; ignore runtime state)
.codex/*
!.codex/config.toml
!.codex/commands
!.codex/prompts

# papyrus-server build output (migrations copied from packages/local-db at build time)
apps/server/resources/

# webui build output
apps/webui/dist/
