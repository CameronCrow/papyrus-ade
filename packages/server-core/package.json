{
	"name": "@papyrus/server-core",
	"version": "0.1.0",
	"description": "Papyrus headless core — Electron-free business logic shared by the desktop app and papyrus-server",
	"private": true,
	"type": "module",
	"exports": {
		"./terminal": {
			"types": "./src/terminal/index.ts",
			"default": "./src/terminal/index.ts"
		},
		"./terminal/daemon": {
			"types": "./src/terminal/daemon/index.ts",
			"default": "./src/terminal/daemon/index.ts"
		},
		"./workspace-runtime": {
			"types": "./src/workspace-runtime/index.ts",
			"default": "./src/workspace-runtime/index.ts"
		},
		"./local-db": {
			"types": "./src/local-db/index.ts",
			"default": "./src/local-db/index.ts"
		},
		"./notifications": {
			"types": "./src/notifications/index.ts",
			"default": "./src/notifications/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"typecheck": "tsc --noEmit --emitDeclarationOnly false",
		"test": "bun test"
	},
	"dependencies": {
		"@superset/local-db": "workspace:*",
		"@superset/shared": "workspace:*",
		"@xterm/addon-serialize": "0.15.0-beta.148",
		"@xterm/headless": "6.1.0-beta.148",
		"better-sqlite3": "12.6.2",
		"default-shell": "^2.2.0",
		"drizzle-orm": "0.45.1",
		"node-pty": "1.1.0",
		"pidtree": "^0.6.0",
		"pidusage": "^4.0.1",
		"simple-git": "^3.30.0",
		"tree-kill": "^1.2.2",
		"uuid": "^13.0.0",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@superset/typescript": "workspace:*",
		"@types/better-sqlite3": "^7.6.13",
		"@types/pidusage": "^2.0.5",
		"bun-types": "^1.3.1",
		"typescript": "^5.9.3"
	}
}
